[user]
    name = {{ .name }}
    email = {{ .email }}
{{- if .signingkey }}
    signingkey = {{ .signingkey }}
[commit]
    gpgsign = true
[tag]
    gpgsign = true
{{- end }}
[push]
    default = upstream
[credential]
    helper = cache
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    required = true
    process = git-lfs filter-process
[core]
    editor = nvim
    excludesfile = ~/.gitignore
[difftool]
    prompt = false
[init]
    defaultBranch = main
[color]
    ui = auto
[branch]
    autoSetupMerge = false
